# Application: convert seconds to H:M:S
total_sec <- 9845L
hh <- total_sec %/% 3600L
mm <- (total_sec %% 3600L) %/% 60L
ss <- total_sec %% 60L
cat(sprintf("\n%d seconds = %02d:%02d:%02d (HH:MM:SS)\n\n", total_sec, hh, mm, ss))

# Logical operators
cat("Logical Operators:\n")
a <- 85; b <- 60; threshold <- 75
cat(sprintf("  a=%d, b=%d, threshold=%d\n", a, b, threshold))
cat(sprintf("  a > threshold && b > threshold  : %s (BOTH pass)\n",
            a > threshold && b > threshold))
cat(sprintf("  a > threshold || b > threshold  : %s (AT LEAST ONE)\n",
            a > threshold || b > threshold))
